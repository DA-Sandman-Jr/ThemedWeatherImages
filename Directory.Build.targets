<Project>
  <PropertyGroup>
    <SyncAgentInstructionsFromClaudeEnabled Condition="'$(SyncAgentInstructionsFromClaudeEnabled)' == ''">true</SyncAgentInstructionsFromClaudeEnabled>
  </PropertyGroup>

  <UsingTask
    TaskName="SyncAgentInstructions"
    TaskFactory="RoslynCodeTaskFactory"
    AssemblyFile="$(MSBuildToolsPath)/Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <RootDirectory ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Code Type="Fragment" Language="cs">
        <![CDATA[
        const string header = "> **Auto-generated from `CLAUDE.md`** - edit the sibling `CLAUDE.md` instead. Changes made directly to this file will be overwritten on the next build by `Directory.Build.targets`.";
        var excludedDirectoryNames = new System.Collections.Generic.HashSet<string>(System.StringComparer.OrdinalIgnoreCase)
        {
            ".git",
            ".vs",
            "bin",
            "obj",
            "node_modules",
            "local-publish",
            "publish"
        };

        var directories = new System.Collections.Generic.Stack<string>();
        directories.Push(System.IO.Path.GetFullPath(RootDirectory));

        while (directories.Count > 0)
        {
            var directory = directories.Pop();
            foreach (var childDirectory in System.IO.Directory.EnumerateDirectories(directory))
            {
                if (!excludedDirectoryNames.Contains(System.IO.Path.GetFileName(childDirectory)))
                {
                    directories.Push(childDirectory);
                }
            }

            foreach (var source in System.IO.Directory.EnumerateFiles(directory, "CLAUDE.md"))
            {
                var destDir = System.IO.Path.GetDirectoryName(source);
                if (string.IsNullOrEmpty(destDir)) continue;
                var dest = System.IO.Path.Combine(destDir, "AGENTS.md");
                var sourceText = System.IO.File.ReadAllText(source)
                    .Replace("\r\n", "\n")
                    .Replace("\r", "\n");
                var agentsText = System.Text.RegularExpressions.Regex.Replace(
                    sourceText,
                    @"`AGENTS\.md` files are auto-generated from sibling `CLAUDE\.md` on build via `Directory\.Build\.targets`\. Edit the `CLAUDE\.md`, not the `AGENTS\.md`\.",
                    "`AGENTS.md` files are auto-generated on build via `Directory.Build.targets`; see the generated header for the source file to edit.",
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                agentsText = System.Text.RegularExpressions.Regex.Replace(
                    agentsText,
                    "CLAUDE\\.md",
                    "AGENTS.md",
                    System.Text.RegularExpressions.RegexOptions.IgnoreCase);
                var newContent = header + "\n\n" + agentsText;
                var existing = System.IO.File.Exists(dest) ? System.IO.File.ReadAllText(dest) : null;
                if (existing != newContent)
                {
                    System.IO.File.WriteAllText(dest, newContent);
                    Log.LogMessage(MessageImportance.Normal, "Synced " + dest);
                }
            }
        }
        ]]>
      </Code>
    </Task>
  </UsingTask>

  <Target Name="SyncAgentInstructionsFromClaude"
          BeforeTargets="PrepareForBuild"
          Condition="'$(SyncAgentInstructionsFromClaudeEnabled)' == 'true' and '$(MSBuildProjectName)' == 'ThemedWeatherImages.Tests'">
    <Message Text="Syncing AGENTS.md files from CLAUDE.md files."
             Importance="High" />
    <SyncAgentInstructions RootDirectory="$(MSBuildThisFileDirectory)" />
  </Target>
</Project>
