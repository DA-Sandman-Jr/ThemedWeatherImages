{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ThemedWeatherImages": {
    "Theme": {
      "DisplayName": "Weather Fox",
      "SubjectName": "fox",
      "SubjectSlug": "fox",
