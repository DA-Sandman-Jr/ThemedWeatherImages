{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit:*)",
            "command": "$CLAUDE_PROJECT_DIR/scripts/claude-format-staged.sh",
            "timeout": 180,
            "statusMessage": "Formatting before commit"
          }
        ]
      }
    ]
  }
}
